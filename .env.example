# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ProxyAPI ключ (https://proxyapi.ru)
PROXYAPI_KEY=your_proxyapi_key_here

# AI модель (OpenAI, Anthropic или Google)
# OpenAI: gpt-5, gpt-4.1, o4-mini
# Anthropic: claude-sonnet-4-5, claude-haiku-4-5, claude-opus-4-1
# Google: gemini-2.5-flash, gemini-2.5-pro, veo-3.1-generate-preview
AI_MODEL=gpt-4o-mini

# Температура генерации (0.0 - 1.0)
# 0.0 - более детерминированные ответы
# 1.0 - более креативные ответы
DEFAULT_TEMPERATURE=0.7

# Таймаут запроса в секундах
REQUEST_TIMEOUT=120

# Максимальное количество попыток запроса
MAX_RETRIES=3

# Задержка между попытками в секундах
RETRY_DELAY=2

# Максимальная длина контекста (количество сообщений)
MAX_CONTEXT_LENGTH=20

# Системный промпт для бота
SYSTEM_PROMPT=Ты полезный ассистент Telegram-бота. Отвечай кратко и по делу на русском языке.
