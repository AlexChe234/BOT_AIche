# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ProxyAPI ключ (https://proxyapi.ru)
PROXYAPI_KEY=your_proxyapi_key_here

# AI модель (OpenAI-совместимые или Claude)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Anthropic: claude-sonnet-4-5, claude-3-opus, claude-3-haiku
AI_MODEL=gpt-4o-mini

# Таймаут запроса в секундах
REQUEST_TIMEOUT=120

# Максимальное количество попыток запроса
MAX_RETRIES=3

# Задержка между попытками в секундах
RETRY_DELAY=2

# Максимальная длина контекста (количество сообщений)
MAX_CONTEXT_LENGTH=20

# Системный промпт для бота
SYSTEM_PROMPT=Ты полезный ассистент Telegram-бота. Отвечай кратко и по делу на русском языке.
